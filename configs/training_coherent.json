{
    "output_dir": "./checkpoints/hnet_bit_coherent",

    "dataset": "roneneldan/TinyStories",
    "val_split": "validation",
    "train_split": "train",
    "text_column": "auto",
    "max_seq_length": 512,

    "max_steps": 30000,
    "batch_size": 32,
    "gradient_accumulation_steps": 4,

    "learning_rate": 2e-4,
    "weight_decay": 0.1,
    "max_grad_norm": 1.0,
    "warmup_steps": 2000,
    "lr_scheduler": "cosine",
    "adam_beta1": 0.9,
    "adam_beta2": 0.95,
    "adam_eps": 1e-8,

    "lr_multipliers": [1.5, 1.0],
    "lambda_lb": 0.03,
    "downsampling_factor": 2.5,

    "eval_interval": 10000,
    "save_interval": 2000,
    "log_interval": 50,

    "bf16": false,
    "fp16": false,

    "seed": 42
}
